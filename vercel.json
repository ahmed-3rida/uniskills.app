{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/(.*)\\.(css|js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(jpg|jpeg|png|gif|svg|ico|webp)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(woff|woff2|ttf|eot)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://www.uniskills.pro/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "uniskills-app.vercel.app"
        }
      ]
    },
    {
      "source": "/(.*)",
      "destination": "/app.html",
      "permanent": false,
      "has": [
        {
          "type": "host",
          "value": "app.uniskills.pro"
        }
      ]
    },
    {
      "source": "/app",
      "destination": "/app.html",
      "permanent": false
    },
    {
      "source": "/download",
      "destination": "/app.html",
      "permanent": false
    },
    {
      "source": "/home",
      "destination": "/",
      "permanent": true
    }
  ]
}